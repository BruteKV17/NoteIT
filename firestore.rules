rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Authenticated users can read and write to their own user document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Authenticated users can read and write to their own notes subcollection
      match /notes/{noteId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Authenticated users can read and write to their own lectures subcollection
      match /lectures/{lectureId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Authenticated users can read and write to their own weakTopics subcollection
      match /weakTopics/{topicId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Authenticated users can read and write to their own recordings subcollection
      match /recordings/{recordingId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Authenticated users can read and write to their own sources subcollection
      match /sources/{sourceId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
